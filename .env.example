# Required: Anthropic API key for Claude analysis
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: FRED API key for macroeconomic data (Fed funds rate, inflation, yield curve)
# Get a free key at https://fred.stlouisfed.org/docs/api/api_key.html
# Without this key, macro section will show "data unavailable"
FRED_API_KEY=your_fred_api_key_here
